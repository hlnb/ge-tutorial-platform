{
  "hooks": {
    "PostToolUse": [
      {
        "event": "PostToolUse",
        "type": "command",
        "command": "npm run lint -- --no-fix 2>&1 | tail -20",
        "timeout": 30,
        "matcher": {
          "toolName": "replace_string_in_file|create_file|multi_replace_string_in_file"
        }
      }
    ]
  }
}
